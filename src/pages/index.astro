---
/**
 * Home page — mapeia patterns/page-home.php
 * Tagline → LatestPost → RecentPosts → TagCloud
 */
import Base from "../layouts/Base.astro";
import { siteConfig } from "../config/site";
import { getCollection } from "astro:content";
import LatestPost from "../components/LatestPost.astro";
import RecentPosts from "../components/RecentPosts.astro";
import TagCloud from "../components/TagCloud.astro";

// Get the latest post id to exclude it from RecentPosts
const posts = await getCollection("posts", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const latestId = posts[0]?.id;
---

<Base title={siteConfig.title} description={siteConfig.description}>
	<div class="constrained home-content">

		<p class="text-subtitle site-tagline">{siteConfig.description}</p>

		<div class="home-section">
			<LatestPost />
		</div>

		<div class="home-section">
			<RecentPosts excludeId={latestId} />
		</div>

		<div class="home-section">
			<TagCloud />
		</div>

	</div>
</Base>

<style>
	.home-content {
		padding-top: var(--space-xs);
		padding-bottom: var(--space-xl);
	}

	.site-tagline {
		margin-bottom: var(--space-xs);
	}

	.home-section {
		margin-top: var(--space-md);
	}
</style>
