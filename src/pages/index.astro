---
/**
 * Home page — mapeia patterns/page-home.php
 * Tagline → LatestPost → RecentPosts → TagCloud
 */
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import LatestPost from "../components/LatestPost.astro";
import RecentPosts from "../components/RecentPosts.astro";
import TagCloud from "../components/TagCloud.astro";
import { siteConfig } from "../config/site";
import { getCollection } from "astro:content";

// Obtém o id do post mais recente para excluí-lo do RecentPosts
const posts = (await getCollection("posts", ({ data }) => !data.draft))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const latestId = posts[0]?.id;
---

<Base title={siteConfig.title} description={siteConfig.description}>
	<Header />
	<main id="main-content" class="constrained home-content">

		<p class="text-subtitle site-tagline">{siteConfig.description}</p>

		<div class="home-section">
			<LatestPost />
		</div>

		<div class="home-section">
			<RecentPosts excludeId={latestId} />
		</div>

		<div class="home-section">
			<p class="text-subtitle">Topics</p>
			<TagCloud />
		</div>

	</main>
	<Footer />
</Base>

<style>
	.home-content {
		padding-top: var(--space-sm);
		padding-bottom: var(--space-xl);
	}

	.site-tagline {
		color: var(--color-6);
		margin-bottom: 0;
	}

	.home-section {
		margin-top: var(--space-xl);
	}
</style>
