---
/**
 * 404 — "Whoops, that page is gone."
 * Maps to WP templates/404.html.
 *
 * Design: centered heading + description + search input, min-height 70vh.
 */
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Page not found">
	<Header />
	<main id="main-content" class="not-found">
		<div class="not-found__inner">
			<h1 class="not-found__heading">Whoops, that page is gone.</h1>
			<p class="not-found__desc">Discover my popular posts, or search for something else.</p>
			<div class="not-found__search">
				<form action="/search" method="get" class="not-found__form">
					<input
						type="search"
						name="q"
						placeholder="Search for posts"
						class="not-found__input"
						aria-label="Search"
					/>
				</form>
			</div>
		</div>
	</main>
	<Footer />
</Base>

<style>
	.not-found {
		min-height: 70vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.not-found__inner {
		width: 100%;
		max-width: 280px;
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.not-found__heading {
		font-size: var(--font-size-xl);
		color: var(--color-6);
		text-wrap: balance;
		margin: 0;
	}

	.not-found__desc {
		color: var(--color-5);
		margin: 0;
	}

	.not-found__search {
		margin-top: 4px;
	}

	.not-found__form {
		display: flex;
	}

	.not-found__input {
		width: 100%;
		padding: var(--space-xs) var(--space-sm);
		border: 1px solid var(--color-3);
		border-radius: 8px;
		background: var(--color-1);
		color: var(--color-6);
		font-family: var(--font-family);
		font-size: var(--font-size-md);
		outline: none;
		transition: border-color 200ms ease;
		box-sizing: border-box;
	}

	.not-found__input:focus-visible {
		border-color: var(--color-5);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-5) 20%, transparent);
	}
</style>
