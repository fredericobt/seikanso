---
/**
 * /posts — Todos os posts, paginados (5 por página).
 * Página 1 → /posts/   Página 2 → /posts/2   etc.
 * Mapeia WP archive.html com listagem completa de posts.
 */
import type { GetStaticPathsOptions, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PostCard from "../../components/PostCard.astro";
import Pagination from "../../components/Pagination.astro";
import TagCloud from "../../components/TagCloud.astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	const posts = (await getCollection("posts", ({ data }) => !data.draft))
		.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
	return paginate(posts, { pageSize: 5 });
}

const { page } = Astro.props as { page: Page<CollectionEntry<"posts">> };
---

<Base title="Posts" description="All posts.">
	<Header />
	<main id="main-content" class="constrained posts-main">
		<div class="posts-header">
			<h1 class="posts-title">Posts</h1>
			<TagCloud />
		</div>

		<div class="posts-list">
			{page.data.map((post, i) => (
				<>
					<PostCard post={post} />
					{i < page.data.length - 1 && <hr class="posts-sep" />}
				</>
			))}
		</div>

		<Pagination page={page} />
	</main>
	<Footer />
</Base>

<style>
	.posts-main {
		padding-top: var(--space-sm);
		padding-bottom: var(--space-xl);
	}

	.posts-header {
		margin-bottom: var(--space-xl);
	}

	.posts-title {
		margin-bottom: var(--space-sm);
	}

	.posts-sep {
		margin: 0;
		border: none;
		border-top: 1px solid var(--color-3);
	}
</style>
