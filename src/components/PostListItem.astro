---
/**
 * PostListItem — título + data em linha com separador
 * Mapeia o item dentro do wp:post-template em posts-recent.php
 * flex row, space-between, separator <hr> abaixo
 */
import type { CollectionEntry } from "astro:content";

interface Props {
	post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { title, publishDate } = post.data;
const slug = post.id;

const date = new Date(publishDate);
const dateFormatted = date.toLocaleDateString("en-US", {
	month: "short",
	year: "numeric",
});
const dateISO = date.toISOString();
---

<div class="post-list-item">
	<div class="post-list-row">
		<a href={`/${slug}`} class="post-list-title">{title}</a>
		<time datetime={dateISO} class="post-list-date">
			<a href={`/${slug}`}>{dateFormatted}</a>
		</time>
	</div>
	<hr class="post-list-separator" />
</div>

<style>
	.post-list-item {
		display: flex;
		flex-direction: column;
	}

	.post-list-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-sm);
		padding-top: 16px;
		padding-bottom: 12px;
	}

	.post-list-title {
		font-size: var(--font-size-md);
		font-weight: 400;
		line-height: 1.2;
		color: var(--color-6);
		text-decoration: none;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		min-width: 0;
	}

	.post-list-title:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.post-list-date {
		font-size: var(--font-size-sm);
		color: var(--color-5);
		line-height: 1.2;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.post-list-date a {
		color: inherit;
		text-decoration: none;
	}

	.post-list-date a:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.post-list-separator {
		margin: 0;
		border: none;
		border-top: 1px solid var(--color-3);
	}
</style>
