---
/**
 * PostListItem — compact title + date row.
 * Used by RecentPosts (with separator) and RelatedPosts (without).
 */
import type { CollectionEntry } from "astro:content";

interface Props {
	post: CollectionEntry<"posts">;
	separator?: boolean;
	titleFontSize?: string;
}

const { post, separator = true, titleFontSize = "var(--font-size-md)" } = Astro.props;
const { title, publishDate } = post.data;
const href = `/${post.id}`;

const dateFormatted = publishDate.toLocaleDateString("en-US", {
	month: "short",
	year: "numeric",
});
---

<div class="post-list-item">
	<div class="post-list-item__row">
		<a href={href} class="post-list-item__title" style={`font-size: ${titleFontSize}`}>
			{title}
		</a>
		<time datetime={publishDate.toISOString()} class="post-list-item__date">
			<a href={href}>{dateFormatted}</a>
		</time>
	</div>
	{separator && <hr class="post-list-item__sep" />}
</div>

<style>
	.post-list-item {
		display: flex;
		flex-direction: column;
	}

	.post-list-item__row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-sm);
		padding-top: 16px;
		padding-bottom: 13px;
	}

	.post-list-item__title {
		/* font-size set via inline style prop */
		font-weight: 550;
		line-height: 1.2;
		color: var(--color-6);
		text-decoration: none;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		min-width: 0;
	}

	.post-list-item__title:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.post-list-item__date {
		font-size: var(--font-size-sm);
		color: var(--color-5);
		line-height: 1.2;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.post-list-item__date a {
		color: inherit;
		text-decoration: none;
	}

	.post-list-item__date a:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.post-list-item__sep {
		margin: 0;
		border: none;
		border-top: 1px solid var(--color-3);
	}
</style>
