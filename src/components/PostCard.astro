---
/**
 * PostCard — título linkado + excerpt + data
 * Mapeia wp:post-template dentro do patterns/posts-latest.php
 */
import type { CollectionEntry } from "astro:content";

interface Props {
	post: CollectionEntry<"posts">;
	excerptLength?: number;
}

const { post, excerptLength = 36 } = Astro.props;
const { title, publishDate, description } = post.data;
const slug = post.id;

const date = new Date(publishDate);
const dateFormatted = date.toLocaleDateString("en-US", {
	month: "short",
	day: "numeric",
	year: "numeric",
});
const dateISO = date.toISOString();

// Trim excerpt to ~excerptLength words
const words = (description ?? "").split(" ");
const excerpt =
	words.length > excerptLength
		? words.slice(0, excerptLength).join(" ") + "…"
		: description;
---

<div class="post-card">
	<h2 class="post-card-title">
		<a href={`/${slug}`}>{title}</a>
	</h2>
	<time datetime={dateISO} class="post-card-date">
		<a href={`/${slug}`}>{dateFormatted}</a>
	</time>
	{
		excerpt && (
			<p class="post-card-excerpt">
				{excerpt}{" "}
				<a href={`/${slug}`} class="keep-reading">
					Keep reading →
				</a>
			</p>
		)
	}
</div>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.post-card-title {
		font-size: var(--font-size-md);
		font-weight: 550;
		line-height: 1.3;
		margin: 0;
	}

	.post-card-title a {
		color: var(--color-6);
		text-decoration: none;
	}

	.post-card-title a:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.post-card-date {
		font-size: var(--font-size-sm);
		color: var(--color-5);
	}

	.post-card-date a {
		color: inherit;
		text-decoration: none;
	}

	.post-card-date a:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.post-card-excerpt {
		font-size: var(--font-size-sm);
		color: var(--color-5);
		margin: 0;
		line-height: 1.6;
	}

	.keep-reading {
		color: var(--color-6);
		text-decoration: none;
		white-space: nowrap;
	}

	.keep-reading:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}
</style>
