---
/**
 * PostCard — card de post para listagens (archive, tag pages).
 * Mapeia WP parts/post.html usado em archive.html (font-size: large).
 *
 * API: recebe CollectionEntry<"posts"> completo para type-safety.
 * Props extras: excerptLength (default 36 palavras, como no WP).
 */
import type { CollectionEntry } from "astro:content";

interface Props {
	post: CollectionEntry<"posts">;
	excerptLength?: number;
}

const { post, excerptLength = 36 } = Astro.props;
const { title, publishDate, description } = post.data;
const href = `/${post.id}`;

const dateFormatted = publishDate.toLocaleDateString("en-US", {
	month: "short",
	day: "numeric",
	year: "numeric",
});

// Trunca excerpt para ~excerptLength palavras, como o bloco wp:post-excerpt
const words = (description ?? "").split(" ");
const excerpt =
	words.length > excerptLength
		? words.slice(0, excerptLength).join(" ") + "…"
		: description;
---

<div class="post-card">
	<h2 class="post-card__title">
		<a href={href}>{title}</a>
	</h2>
	<time datetime={publishDate.toISOString()} class="post-card__date">
		<a href={href}>{dateFormatted}</a>
	</time>
	{excerpt && (
		<p class="post-card__excerpt">
			{excerpt}{" "}
			<a href={href} class="post-card__more">Keep reading →</a>
		</p>
	)}
</div>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		padding: var(--space-sm) 0 var(--space-2xl);
	}

	.post-card__title {
		font-size: var(--font-size-lg);
		font-weight: 550;
		line-height: 1.3;
		margin: 0;
	}

	.post-card__title a {
		color: var(--color-6);
		text-decoration: none;
	}

	.post-card__title a:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.post-card__date {
		font-size: var(--font-size-sm);
		color: var(--color-5);
	}

	.post-card__date a {
		color: inherit;
		text-decoration: none;
	}

	.post-card__date a:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.post-card__excerpt {
		font-size: var(--font-size-sm);
		color: var(--color-5);
		margin: 0;
		line-height: 1.6;
	}

	.post-card__more {
		color: var(--color-6);
		text-decoration: none;
		white-space: nowrap;
	}

	.post-card__more:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}
</style>
