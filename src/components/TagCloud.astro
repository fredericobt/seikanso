---
/**
 * TagCloud — tags como pills clicáveis.
 * Mapeia core/tag-cloud do theme.json.
 *
 * Sem label interno — o pai decide o título (ex: "Topics" em index.astro,
 * nenhum em tags/[tag].astro). Tags ordenadas alfabeticamente.
 *
 * Visual: pill shape (border-radius 100px), igual ao tag-pill do Post.astro,
 * fiel ao estilo rounded do WP Kanso.
 */
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => !data.draft);

const tagSet = new Set<string>();
for (const post of posts) {
	for (const tag of post.data.tags) {
		tagSet.add(tag);
	}
}
const tags = [...tagSet].sort();
---

{tags.length > 0 && (
	<div class="tag-cloud">
		{tags.map(tag => (
			<a href={`/tags/${tag}`} class="tag-pill">{tag}</a>
		))}
	</div>
)}

<style>
	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.tag-pill {
		display: flex;
		align-items: center;
		padding: 0 var(--space-sm);
		border: 1px solid var(--color-3);
		border-radius: var(--space-xs);
		font-size: var(--font-size-sm);
		color: var(--color-6);
		text-decoration: none;
		line-height: 1.6;
		transition: border-color var(--transition-duration) ease, color var(--transition-duration) ease;
	}

	.tag-pill:hover {
		border-color: var(--color-5);
		color: var(--color-6);
	}
</style>
