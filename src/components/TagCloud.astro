---
/**
 * TagCloud — tags como pills clicáveis.
 * Mapeia core/tag-cloud do theme.json.
 *
 * Sem label interno — o pai decide o título (ex: "Topics" em index.astro,
 * nenhum em tags/[tag].astro). Tags ordenadas alfabeticamente.
 *
 * Visual: pill shape (border-radius 100px), igual ao tag-pill do Post.astro,
 * fiel ao estilo rounded do WP Kanso.
 */
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => !data.draft);

const tagSet = new Set<string>();
for (const post of posts) {
	for (const tag of post.data.tags) {
		tagSet.add(tag);
	}
}
const tags = [...tagSet].sort();
---

{tags.length > 0 && (
	<div class="tag-cloud">
		{tags.map(tag => (
			<a href={`/tags/${tag}`} class="tag-pill">{tag}</a>
		))}
	</div>
)}

<style>
	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.tag-pill {
		display: inline-block;
		padding: 2px 10px;
		border: 1px solid var(--color-4);
		border-radius: 100px;
		font-size: 12px;
		color: var(--color-5);
		text-decoration: none;
		line-height: 1.6;
		transition: transform 200ms ease, border-color 200ms ease, color 200ms ease;
	}

	.tag-pill:hover {
		transform: scale(1.05);
		border-color: var(--color-5);
		color: var(--color-6);
	}
</style>
