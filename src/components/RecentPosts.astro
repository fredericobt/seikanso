---
/**
 * RecentPosts — lista de posts recentes em section-3 card.
 * Mapeia patterns/posts-recent.php e a seção "Posts" de page-home.php.
 *
 * Design: label "Posts" + section-3 card com PostListItems (título + data,
 * separados por hr) + botão "View all posts →" full-width.
 *
 * Props:
 *   limit     — quantidade de posts (default: 5, como no WP perPage: 5)
 *   excludeId — id do post a excluir (evita duplicar o LatestPost)
 */
import { getCollection } from "astro:content";
import PostListItem from "./PostListItem.astro";

interface Props {
	limit?: number;
	excludeId?: string;
}

const { limit = 5, excludeId } = Astro.props;

const posts = (await getCollection("posts", ({ data }) => !data.draft))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.filter(p => p.id !== excludeId)
	.slice(0, limit);
---

{posts.length > 0 && (
	<section class="recent-posts">
		<p class="text-subtitle">Posts</p>
		<div class="recent-posts__card section-3">
			<div class="recent-posts__list">
				{posts.map(post => (
					<PostListItem post={post} />
				))}
			</div>
			<a href="/posts" class="btn recent-posts__btn">
				View all posts <strong>→</strong>
			</a>
		</div>
	</section>
)}

<style>
	.recent-posts {
		display: flex;
		flex-direction: column;
	}

	.recent-posts__card {
		padding: var(--space-sm) var(--space-md);
	}

	.recent-posts__list {
		display: flex;
		flex-direction: column;
	}

	.recent-posts__btn {
		display: block;
		width: 100%;
		text-align: center;
		margin-top: var(--space-sm);
		box-sizing: border-box;
	}
</style>
