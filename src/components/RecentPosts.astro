---
/**
 * RecentPosts — lista de posts recentes com separadores + botão "View all posts →"
 * Mapeia patterns/posts-recent.php
 * section-3 card, 5 posts em PostListItem, botão full-width
 */
import { getCollection } from "astro:content";
import PostListItem from "./PostListItem.astro";

interface Props {
	/** Quantos posts exibir (default: 5) */
	limit?: number;
	/** Slug do post a excluir (ex: o post já exibido em LatestPost) */
	excludeId?: string;
}

const { limit = 5, excludeId } = Astro.props;

const posts = await getCollection("posts", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const recent = posts
	.filter((p) => p.id !== excludeId)
	.slice(0, limit);
---

{
	recent.length > 0 && (
		<section class="recent-posts">
			<p class="text-subtitle">Posts</p>
			<div class="section-3 recent-card">
				<div class="recent-list">
					{recent.map((post) => (
						<PostListItem post={post} />
					))}
				</div>
				<div class="view-all-wrap">
					<a href="/posts" class="btn view-all-btn">
						View all posts <strong>→</strong>
					</a>
				</div>
			</div>
		</section>
	)
}

<style>
	.recent-posts {
		display: flex;
		flex-direction: column;
	}

	.recent-card {
		padding: 6px var(--space-md) 26px;
	}

	.recent-list {
		display: flex;
		flex-direction: column;
	}

	.view-all-wrap {
		margin-top: var(--space-sm);
	}

	.view-all-btn {
		display: block;
		width: 100%;
		text-align: center;
		box-sizing: border-box;
	}
</style>
