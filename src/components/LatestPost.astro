---
/**
 * LatestPost — card destaque do post mais recente.
 * Mapeia patterns/posts-latest.php (font-size: medium).
 */
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const latest = posts[0];
if (!latest) return;

const href = `/${latest.id}`;
const dateFormatted = latest.data.publishDate.toLocaleDateString("en-US", {
	month: "short",
	day: "numeric",
	year: "numeric",
});

const excerptLength = 36;
const words = (latest.data.description ?? "").split(" ");
const excerpt = words.length > excerptLength
	? words.slice(0, excerptLength).join(" ") + "…"
	: latest.data.description;
---

<section class="latest-post">
		<p class="text-subtitle">Latest</p>
		<div class="latest-post__card section-3">
			<h2 class="latest-post__title">
				<a href={href}>{latest.data.title}</a>
			</h2>
			<time datetime={latest.data.publishDate.toISOString()} class="latest-post__date">
				<a href={href}>{dateFormatted}</a>
			</time>
			{excerpt && (
				<p class="latest-post__excerpt">
					{excerpt}{" "}
					<a href={href} class="latest-post__more">Keep reading →</a>
				</p>
			)}
		</div>
	</section>

<style>
	.latest-post {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.latest-post__card {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		padding: var(--space-md);
	}

	.latest-post__title {
		font-size: var(--font-size-md);
		font-weight: 550;
		line-height: 1.3;
		margin: 0;
	}

	.latest-post__title a {
		color: var(--color-6);
		text-decoration: none;
	}

	.latest-post__title a:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.latest-post__date {
		font-size: var(--font-size-sm);
		color: var(--color-5);
	}

	.latest-post__date a {
		color: inherit;
		text-decoration: none;
	}

	.latest-post__date a:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.latest-post__excerpt {
		font-size: var(--font-size-body);
		color: var(--color-6);
		margin: 0;
		line-height: 1.6;
	}

	.latest-post__more {
		color: var(--color-6);
		text-decoration: underline;
		text-underline-offset: 2px;
		white-space: nowrap;
	}

	.latest-post__more:hover {
		text-decoration: none;
	}
</style>
