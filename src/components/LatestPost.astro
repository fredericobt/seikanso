---
/**
 * LatestPost — card destaque do post mais recente.
 * Mapeia patterns/posts-latest.php e a seção "Latest" de page-home.php.
 *
 * Design: label "Latest" + section-3 card com título (font-size: medium,
 * como no WP), data (M j, Y) e excerpt inline com "Keep reading →".
 *
 * Implementação autônoma (não depende de PostCard) para usar font-size-md
 * conforme o WP posts-latest.php (fontSize: "medium"), enquanto PostCard
 * usa font-size-lg para o contexto de archive.
 */
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const latest = posts[0];
if (!latest) return;

const href = `/${latest.id}`;
const dateFormatted = latest.data.publishDate.toLocaleDateString("en-US", {
	month: "short",
	day: "numeric",
	year: "numeric",
});

// Excerpt: primeiras 36 palavras da description, como wp:post-excerpt
const words = (latest.data.description ?? "").split(" ");
const excerpt = words.length > 36
	? words.slice(0, 36).join(" ") + "…"
	: latest.data.description;
---

{latest && (
	<section class="latest-post">
		<p class="text-subtitle">Latest</p>
		<div class="latest-post__card section-3">
			<h2 class="latest-post__title">
				<a href={href}>{latest.data.title}</a>
			</h2>
			<time datetime={latest.data.publishDate.toISOString()} class="latest-post__date">
				<a href={href}>{dateFormatted}</a>
			</time>
			{excerpt && (
				<p class="latest-post__excerpt">
					{excerpt}{" "}
					<a href={href} class="latest-post__more">Keep reading →</a>
				</p>
			)}
		</div>
	</section>
)}

<style>
	.latest-post {
		display: flex;
		flex-direction: column;
	}

	.latest-post__card {
		padding: 22px var(--space-md);
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.latest-post__title {
		font-size: var(--font-size-md);
		font-weight: 550;
		line-height: 1.3;
		margin: 0;
	}

	.latest-post__title a {
		color: var(--color-6);
		text-decoration: none;
	}

	.latest-post__title a:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.latest-post__date {
		font-size: var(--font-size-sm);
		color: var(--color-5);
	}

	.latest-post__date a {
		color: inherit;
		text-decoration: none;
	}

	.latest-post__date a:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.latest-post__excerpt {
		font-size: var(--font-size-sm);
		color: var(--color-5);
		margin: 0;
		line-height: 1.6;
	}

	.latest-post__more {
		color: var(--color-6);
		text-decoration: none;
		white-space: nowrap;
	}

	.latest-post__more:hover {
		text-decoration: underline;
		text-underline-offset: 2px;
	}
</style>
